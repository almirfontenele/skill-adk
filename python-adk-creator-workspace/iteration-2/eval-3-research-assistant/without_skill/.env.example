# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Required — get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional — Gemini model to use (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Optional — SerpAPI key for richer Google Search results
# Get a free key at https://serpapi.com/
# If not set, the assistant falls back to DuckDuckGo Instant Answers.
SERPAPI_KEY=

# Optional — number of search results to return (default: 5)
MAX_SEARCH_RESULTS=5

# Optional — approximate max words in text summaries (default: 300)
SUMMARY_MAX_WORDS=300
